rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ─────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'thejestamang@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── ADMIN WILDCARD — full access to everything ────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }


    // ── PUBLIC CONTENT COLLECTIONS ───────────────────────────────────────────
    // These power public-facing pages and must be readable without auth.

    match /lyrics/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /releases/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /photos/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /entities/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /videos/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /pressArticles/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /merch/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /sigilCards/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /navBadges/{docId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    // ── LEADERBOARDS & SCORES ────────────────────────────────────────────────
    match /leaderboards/{entryId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /scores/{entryId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isAdmin();
    }


    // ── COMMENTS ─────────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }


    // ── BLOG POSTS ───────────────────────────────────────────────────────────
    match /blogPosts/{postId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    // ── SHOWS ────────────────────────────────────────────────────────────────
    match /shows/{showId} {
      allow read:  if true;
      allow write: if isAdmin();
    }


    // ── GUESTBOOK ────────────────────────────────────────────────────────────
    match /guestbook/{userId} {
      allow read:   if true;
      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && !exists(/databases/$(database)/documents/guestbook/$(request.auth.uid));
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }


    // ── INNER CIRCLE CHAT ────────────────────────────────────────────────────
    match /innerCircleChat/{messageId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false;
      allow delete: if isOwner(resource.data.uid) || isAdmin();
    }


    // ── USERS ────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read:  if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/natalChart/{docId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }


    // ── TREATS ───────────────────────────────────────────────────────────────
    match /treats/{docId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }


    // ── FAVORITES ────────────────────────────────────────────────────────────
    match /favorites/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /{item=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }


    // ── INQUIRIES ────────────────────────────────────────────────────────────
    match /inquiries/{inquiryId} {
      allow read, write: if isAdmin();
      allow create:      if true;
    }


    // ── NOTIFICATIONS ────────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, write: if isAdmin();
    }


    // ── EMAIL CAMPAIGNS ──────────────────────────────────────────────────────
    match /emailCampaigns/{docId} {
      allow read, write: if isAdmin();
    }

  }
}
